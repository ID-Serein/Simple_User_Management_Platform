# Copy this file to .env for local development. Never commit .env.

FLASK_SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
REQUIRE_CONFIGURED_SECRET=1

# Used only when the local user store does not exist yet.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password-at-least-12-characters
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PHONE=

USER_STORE_PATH=data/users.json
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
SESSION_MINUTES=30

LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

SECURITY_ENABLE_HSTS=0
FLASK_DEBUG=0
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
